function getPool(id){return state.pools.find(function(p){return p.id===id;});}
function getItemsInPool(pid){return state.items.filter(function(i){return i.poolId===pid;});}
function getUnassigned(){return state.items.filter(function(i){return!i.poolId;});}
function getPoolTotalQty(pid){return getItemsInPool(pid).reduce(function(s,i){return s+i.qty;},0);}
function getItem(id){return state.items.find(function(i){return i.id===id;});}
function itemLabel(item){
