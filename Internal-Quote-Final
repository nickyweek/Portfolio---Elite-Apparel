}

// ── POOL MANAGEMENT ──────────────────────────────────────────────────────────
function createPool(deco){
  var id=state.nextPoolId++;
  var pool={id:id,name:'Imprint '+id,deco:deco,locations:[]};
  if(deco==='screenprint')pool.locations=[{name:'Left Chest',spColors:1}];
  else pool.locations=[{name:'Left Chest',embStitches:8000}];
  state.pools.push(pool);
  return pool;
}
function deletePool(pid){
  state.items.forEach(function(i){if(i.poolId===pid)i.poolId=null;});
  state.pools=state.pools.filter(function(p){return p.id!==pid;});
  renderAll();
}
function removeFromPool(itemId){var item=getItem(itemId);if(item){item.poolId=null;renderAll();}}

// ── CALC ─────────────────────────────────────────────────────────────────────
function calcAtTierQty(item,tierRepQty){
  var pool=item.poolId?getPool(item.poolId):null;
  var deco=pool?pool.deco:null;if(!deco)return null;
  var locations=pool.locations||[];
  var m=getmd(tierRepQty,deco);
  var garment=item.wholesale;
  var decoSum=0;
  locations.forEach(function(loc){
    if(deco==='screenprint')decoSum+=spDeco(tierRepQty,loc.spColors||1);
    else decoSum+=embDeco(item.qty,loc.embStitches||8000);
  });
  var screenCharges=0,screenPerUnit=0;
  if(deco==='screenprint'&&tierRepQty<144){
    locations.forEach(function(loc){screenCharges+=(loc.spColors||1)*20;});
    screenPerUnit=screenCharges/tierRepQty;
  }
  var totalCost=garment+decoSum+screenPerUnit;
  var rawPrice=totalCost/m;
  var recommended=Math.ceil(rawPrice);
  return{garment:garment,deco:decoSum,screenCharges:screenCharges,screenPerUnit:screenPerUnit,totalCost:totalCost,rawPrice:rawPrice,recommended:recommended,profit:recommended-totalCost};
}

// ── MUTATIONS ────────────────────────────────────────────────────────────────
function addItem(styleNum,name,wholesale){
  var id=Date.now()+Math.random();
  state.items.push({id:id,styleNum:styleNum||'',name:name||'',wholesale:wholesale||0,qty:24,poolId:null,lookupMsg:'',lookupOk:false});
  return id;
}
function removeItem(id){state.items=state.items.filter(function(i){return i.id!==id;});renderAll();}
function onQtyChange(id,val){var item=getItem(id);if(item){item.qty=Math.max(1,parseInt(val)||1);renderOutput();renderBE();}}
function onWholesaleChange(id,val){var item=getItem(id);if(item){item.wholesale=parseFloat(val)||0;renderOutput();}}
function onStyleInput(id,val){var item=getItem(id);if(item)item.styleNum=val.trim().toUpperCase();}

function lookupForItem(id){
  var item=getItem(id);if(!item)return;
  if(!item.styleNum){showLookupMsg(id,'Enter a style number first','err');return;}
  if(!state.sanmarData){showLookupMsg(id,'Sheet not connected','err');return;}
  var result=lookupStyle(item.styleNum);
  if(result){
    item.name=result.name;item.wholesale=result.wholesale;
    item.lookupMsg='$'+result.wholesale+' — '+result.name;item.lookupOk=true;
  } else {
    item.lookupMsg='Not found — enter price manually';item.lookupOk=false;
  }
  renderAll();
}

function showLookupMsg(id,msg,type){
  var item=getItem(id);if(!item)return;
  item.lookupMsg=msg;item.lookupOk=type==='ok';
  renderBE();
}

function onPoolLocChange(poolId,li,field,val){
  var pool=getPool(poolId);if(!pool||!pool.locations[li])return;
  if(field==='spColors')pool.locations[li].spColors=Math.max(1,Math.min(8,parseInt(val)||1));
  else if(field==='embStitches')pool.locations[li].embStitches=parseInt(val)||8000;
  else pool.locations[li].name=val;
  renderBE();renderOutput();
}
function addPoolLoc(pid){
  var pool=getPool(pid);if(!pool)return;
  var loc={name:'Left Chest'};
  if(pool.deco==='screenprint')loc.spColors=1;else loc.embStitches=8000;
  pool.locations.push(loc);renderBE();renderOutput();
}
function removePoolLoc(pid,li){var pool=getPool(pid);if(!pool)return;pool.locations.splice(li,1);renderBE();renderOutput();}
function onPoolNameChange(pid,val){var pool=getPool(pid);if(pool){pool.name=val;}renderOutput();}

function assignChecked(){
  var sel=document.getElementById('ua-pool-sel');if(!sel)return;
  var val=sel.value;
  var checked=Array.from(document.querySelectorAll('.ua-cb:checked')).map(function(cb){return parseFloat(cb.dataset.id);});
  if(!checked.length){alert('Select at least one garment first.');return;}
  var poolId;
  if(val==='new-sp')poolId=createPool('screenprint').id;
  else if(val==='new-emb')poolId=createPool('embroidery').id;
  else poolId=parseInt(val);
  checked.forEach(function(id){var item=getItem(id);if(item)item.poolId=poolId;});
  renderAll();
}

// ── BULK ENTRY ───────────────────────────────────────────────────────────────
function processBulkInput(){
  var inp=document.getElementById('bulk-input');
  var val=inp.value.trim();if(!val)return;
  var styles=val.split(',').map(function(s){return s.trim().toUpperCase();}).filter(Boolean);
  styles.forEach(function(s){
    var id=addItem(s);
    if(state.sanmarData){
      var result=lookupStyle(s);var item=getItem(id);
      if(item&&result){item.name=result.name;item.wholesale=result.wholesale;item.lookupMsg='$'+result.wholesale;item.lookupOk=true;}
      else if(item){item.lookupMsg='Not found';item.lookupOk=false;}
    }
  });
  inp.value='';renderAll();
}
document.getElementById('bulk-input').addEventListener('keydown',function(e){if(e.key==='Enter')processBulkInput();});
document.getElementById('btn-bulk-add').addEventListener('click',processBulkInput);
document.getElementById('btn-add-garment').addEventListener('click',function(){
  var sn=prompt('Enter style number (e.g. NL6210):','');
  if(sn===null)return;
  sn=sn.trim().toUpperCase();
  var id=addItem(sn);
  if(sn&&state.sanmarData){
    var result=lookupStyle(sn);var item=getItem(id);
    if(item&&result){item.name=result.name;item.wholesale=result.wholesale;item.lookupMsg='$'+result.wholesale;item.lookupOk=true;}
    else if(item&&sn){item.lookupMsg='Not found — enter price manually';item.lookupOk=false;}
  }
  renderAll();
});

