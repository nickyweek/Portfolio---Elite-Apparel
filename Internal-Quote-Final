<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Elite Apparel — Quote Builder</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --black:#0D0D0D;--white:#FFFFFF;
  --gray-25:#FAFAFA;--gray-50:#F5F5F5;--gray-100:#EBEBEB;--gray-200:#D6D6D6;--gray-300:#BABABA;--gray-400:#919191;--gray-500:#6B6B6B;--gray-600:#444;--gray-700:#2E2E2E;--gray-800:#1C1C1C;
  --green:#059669;--green-dim:#D1FAE5;--green-mid:#065F46;
  --blue:#1D4ED8;--blue-dim:#DBEAFE;
  --amber:#B45309;--amber-dim:#FEF3C7;
  --purple:#6D28D9;--purple-dim:#EDE9FE;
  --red:#DC2626;--red-dim:#FEE2E2;
  --sp-color:#065F46;--sp-bg:#ECFDF5;
  --emb-color:#3730A3;--emb-bg:#EEF2FF;
  --radius:3px;
}
html,body{height:100%;overflow:hidden}
body{font-family:'DM Sans',sans-serif;background:var(--gray-50);color:var(--black);display:flex;flex-direction:column}

/* ── TOP BAR ── */
.topbar{background:var(--black);height:52px;display:flex;align-items:center;padding:0 20px;gap:16px;flex-shrink:0;border-bottom:1px solid #222}
.topbar-logo{height:28px;width:auto;flex-shrink:0}
.topbar-divider{width:1px;height:20px;background:#333;flex-shrink:0}
.topbar-label{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--gray-400)}
.topbar-spacer{flex:1}
.sheet-pill{font-size:10px;font-weight:600;letter-spacing:.06em;padding:4px 10px;border-radius:99px}
.sheet-pill.ok{background:#052e16;color:#6ee7b7}
.sheet-pill.loading{background:#1c1400;color:#fbbf24}
.sheet-pill.error{background:#1c0000;color:#f87171}
.sheet-pill.idle{background:#1a1a1a;color:var(--gray-500)}

/* ── ENTRY BAR ── */
.entrybar{background:var(--gray-800);padding:8px 16px;display:flex;align-items:center;gap:8px;flex-shrink:0;border-bottom:1px solid #111}
.entry-label{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gray-400);white-space:nowrap}
.entry-input{flex:1;padding:7px 12px;background:#111;border:1px solid #333;color:var(--white);font-family:'DM Sans',sans-serif;font-size:12px;border-radius:var(--radius);min-width:0}
.entry-input:focus{outline:none;border-color:var(--green)}
.entry-input::placeholder{color:#444}
.entry-btn{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:7px 16px;border:none;border-radius:var(--radius);cursor:pointer;white-space:nowrap;flex-shrink:0}
.entry-btn.primary{background:var(--green);color:#fff}
.entry-btn.primary:hover{background:#047857}
.entry-btn.secondary{background:#2a2a2a;color:var(--gray-300);border:1px solid #3a3a3a}
.entry-btn.secondary:hover{background:#333}

/* ── APP LAYOUT ── */
.app{display:grid;grid-template-columns:460px 1fr;flex:1;overflow:hidden;min-height:0}

/* ── LEFT — BULK EDITOR ── */
.be-col{overflow-y:auto;border-right:1px solid var(--gray-100);background:var(--white)}

.be-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:200px;gap:8px;color:var(--gray-400)}
.be-empty-icon{font-size:32px;opacity:.3}
.be-empty p{font-size:13px;font-weight:500}
.be-empty-sub{font-size:11px!important;color:var(--gray-300)!important}

.be-section{border-bottom:1px solid var(--gray-100)}
.be-section-hdr{padding:10px 14px;display:flex;align-items:center;justify-content:space-between;gap:8px;flex-wrap:wrap;position:sticky;top:0;z-index:10}
.unassigned-section .be-section-hdr{background:var(--gray-50);border-bottom:1px solid var(--gray-100)}
.pool-section .be-section-hdr{background:var(--black)}
.pool-sp .be-section-hdr{background:var(--black)}
.pool-emb .be-section-hdr{background:#0f172a}

.be-section-left{display:flex;align-items:center;gap:8px;min-width:0;flex:1}
.be-section-badge{font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:800;letter-spacing:.18em;padding:3px 7px;border-radius:2px;text-transform:uppercase;flex-shrink:0}
.unassigned-badge{background:var(--gray-200);color:var(--gray-500)}
.sp-badge{background:#052e16;color:#6ee7b7}
.emb-badge{background:#1e1b4b;color:#a5b4fc}
.be-section-count{font-size:11px;color:var(--gray-400);font-weight:300}
.be-pool-name{background:transparent;border:none;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:800;color:var(--white);text-transform:uppercase;letter-spacing:.06em;width:140px;padding:0;border-bottom:1px solid transparent}
.be-pool-name:focus{outline:none;border-bottom-color:var(--green)}
.be-tier-chip{font-size:10px;color:var(--gray-400);background:rgba(255,255,255,.08);padding:2px 8px;border-radius:99px;white-space:nowrap}
.be-section-actions{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.be-dropdown{padding:5px 8px;background:#111;border:1px solid #333;color:var(--gray-300);font-family:'DM Sans',sans-serif;font-size:11px;border-radius:var(--radius);cursor:pointer}
.be-action-btn{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:5px 12px;background:var(--green);color:#fff;border:none;border-radius:var(--radius);cursor:pointer}
.be-action-btn:hover{background:#047857}
.be-delete-btn{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:4px 10px;background:transparent;border:1px solid #444;color:var(--gray-400);border-radius:var(--radius);cursor:pointer}
.be-delete-btn:hover{border-color:var(--red);color:var(--red)}

/* LOCATION EDITOR */
.be-loc-editor{padding:10px 14px 8px;background:var(--gray-25);border-bottom:1px solid var(--gray-100)}
.be-loc-header{font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--gray-400);margin-bottom:6px}
.be-loc-note{font-weight:400;text-transform:none;letter-spacing:0;color:var(--gray-300)}
.be-loc-row{display:flex;align-items:center;gap:6px;margin-bottom:5px;flex-wrap:wrap}
.be-loc-select{flex:1;min-width:120px;padding:5px 8px;background:var(--white);border:1px solid var(--gray-200);font-family:'DM Sans',sans-serif;font-size:11px;color:var(--black);border-radius:var(--radius)}
.be-loc-field-wrap{display:flex;align-items:center;gap:4px}
.be-loc-num{width:48px;padding:5px 6px;background:var(--white);border:1px solid var(--gray-200);font-family:'DM Sans',sans-serif;font-size:11px;color:var(--black);border-radius:var(--radius);text-align:center}
.be-loc-unit{font-size:10px;color:var(--gray-400)}
.be-sc-badge{font-size:10px;font-weight:600;color:var(--amber);background:var(--amber-dim);padding:2px 7px;border-radius:99px;white-space:nowrap}
.be-rm-loc{font-size:14px;color:var(--gray-300);background:none;border:none;cursor:pointer;line-height:1;padding:2px 4px;border-radius:var(--radius)}
.be-rm-loc:hover{color:var(--red);background:var(--red-dim)}
.be-add-loc{font-family:'Barlow Condensed',sans-serif;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:5px 12px;background:transparent;border:1px dashed var(--gray-200);color:var(--gray-400);border-radius:var(--radius);cursor:pointer;margin-top:2px}
.be-add-loc:hover{border-color:var(--black);color:var(--black);background:var(--gray-50)}

/* ITEM ROWS */
.be-items{padding:4px 14px 6px}
.be-pool-empty{font-size:11px;color:var(--gray-300);font-style:italic;padding:10px 14px;text-align:center}
.be-item{display:flex;align-items:flex-start;gap:8px;padding:7px 0;border-bottom:1px solid var(--gray-50)}
.be-item:last-child{border-bottom:none}
.pool-item{padding:7px 0}
.be-checkbox{flex-shrink:0;margin-top:4px}
.be-checkbox input{cursor:pointer;width:14px;height:14px;accent-color:var(--green)}
.be-item-body{flex:1;min-width:0}
.be-item-top{display:flex;align-items:flex-start;gap:6px;flex-wrap:wrap}
.be-item-label{flex:1;min-width:100px;display:flex;align-items:center;gap:5px;flex-wrap:wrap;padding-top:2px}
.lbl-sku{font-family:'Barlow Condensed',sans-serif;font-size:13px;font-weight:800;letter-spacing:.04em;color:var(--black)}
.lbl-sep{color:var(--gray-300);font-size:11px}
.lbl-name{font-size:11px;color:var(--gray-500);font-weight:400}
.lbl-empty{font-size:11px;color:var(--gray-300);font-style:italic}
.be-item-controls{display:flex;align-items:flex-end;gap:5px;flex-wrap:wrap}
.be-field-group{display:flex;flex-direction:column;gap:2px}
.be-field-lbl{font-family:'Barlow Condensed',sans-serif;font-size:8px;font-weight:700;letter-spacing:.12em;color:var(--gray-400)}
.be-num-field{width:52px;padding:4px 6px;background:var(--gray-50);border:1px solid var(--gray-200);font-family:'DM Sans',sans-serif;font-size:11px;color:var(--black);border-radius:var(--radius);text-align:center}
.be-num-field:focus{outline:none;border-color:var(--green);background:var(--white)}
.price-field{width:64px;text-align:left}
.be-price-wrap{display:flex;align-items:center;border:1px solid var(--gray-200);border-radius:var(--radius);background:var(--gray-50);overflow:hidden}
.be-dollar{padding:0 5px;font-size:11px;color:var(--gray-400);background:var(--gray-100);border-right:1px solid var(--gray-200);height:26px;display:flex;align-items:center}
.be-price-wrap .be-num-field{border:none;border-radius:0;background:transparent;width:60px}
.be-style-wrap{display:flex;border:1px solid var(--gray-200);border-radius:var(--radius);overflow:hidden;background:var(--gray-50)}
.be-style-field{width:68px;padding:4px 6px;background:transparent;border:none;font-family:'DM Sans',sans-serif;font-size:11px;color:var(--black);text-transform:uppercase}
.be-style-field:focus{outline:none;background:var(--white)}
.be-lookup-btn{padding:0 7px;background:var(--black);color:var(--white);border:none;cursor:pointer;font-size:12px;height:26px;flex-shrink:0}
.be-lookup-btn:hover{background:var(--green)}
.be-unassign-btn{width:24px;height:24px;background:var(--amber-dim);color:var(--amber);border:none;border-radius:var(--radius);cursor:pointer;font-size:13px;display:flex;align-items:center;justify-content:center;align-self:flex-end}
.be-unassign-btn:hover{background:var(--amber);color:var(--white)}
.be-remove-item-btn{width:24px;height:24px;background:var(--red-dim);color:var(--red);border:none;border-radius:var(--radius);cursor:pointer;font-size:12px;display:flex;align-items:center;justify-content:center;align-self:flex-end}
.be-remove-item-btn:hover{background:var(--red);color:var(--white)}
.be-lookup-msg{font-size:10px;margin-top:4px;padding:3px 8px;border-radius:var(--radius)}
.msg-ok{background:var(--green-dim);color:var(--green-mid)}
.msg-err{background:var(--red-dim);color:var(--red)}

/* ── RIGHT — OUTPUT ── */
.out-col{display:flex;flex-direction:column;overflow:hidden;background:var(--gray-25)}

/* OUTPUT TOP BAR */
.out-topbar{background:var(--white);border-bottom:1px solid var(--gray-100);padding:10px 16px;display:flex;align-items:flex-start;gap:16px;flex-shrink:0;flex-wrap:wrap}
.out-title{font-family:'Barlow Condensed',sans-serif;font-size:14px;font-weight:800;text-transform:uppercase;letter-spacing:.1em;color:var(--black);padding-top:2px;flex-shrink:0}
.out-filters{display:flex;gap:12px;flex-wrap:wrap;flex:1}
.filter-block{display:flex;flex-direction:column;gap:4px}
.filter-block-label{font-family:'Barlow Condensed',sans-serif;font-size:8px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--gray-400)}
.tier-row{display:flex;align-items:center;gap:3px;flex-wrap:wrap}
.tier-ctrl{font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;padding:2px 8px;background:transparent;border:1px solid var(--gray-200);color:var(--gray-400);border-radius:var(--radius);cursor:pointer}
.tier-ctrl:hover{background:var(--gray-100);color:var(--black)}
.tier-pill{display:flex;align-items:center;cursor:pointer;padding:3px 7px;border:1px solid var(--gray-200);border-radius:var(--radius);font-size:10px;color:var(--gray-500);white-space:nowrap;transition:all .1s;user-select:none}
.tier-pill:has(input:checked){background:var(--black);color:var(--white);border-color:var(--black)}
.tier-pill input{display:none}
.filter-select{padding:5px 8px;background:var(--white);border:1px solid var(--gray-200);font-family:'DM Sans',sans-serif;font-size:11px;color:var(--black);border-radius:var(--radius);cursor:pointer}
.pdf-export-btn{font-family:'Barlow Condensed',sans-serif;font-size:11px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:7px 16px;background:var(--black);color:var(--white);border:none;border-radius:var(--radius);cursor:pointer;display:flex;align-items:center;gap:6px;align-self:flex-start;flex-shrink:0;margin-left:auto}
.pdf-export-btn:hover{background:var(--green)}

/* OUTPUT SCROLL */
.out-scroll{flex:1;overflow-y:auto;padding:14px 16px 48px}
.out-empty{display:flex;flex-direction:column;align-items:center;justify-content:center;height:300px;gap:10px;color:var(--gray-400)}
.out-empty-icon{font-size:40px;opacity:.2}
.out-empty p{font-size:13px;font-weight:500}

/* POOL STRIP */
.pool-strip{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px}
.pool-chip{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius);padding:8px 12px;min-width:140px}
.pool-chip-name{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;color:var(--black);margin-bottom:4px}
.pool-chip-meta{display:flex;align-items:center;gap:5px;flex-wrap:wrap}
.deco-pill-sm{font-size:8px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:2px 5px;border-radius:2px}
.deco-pill-sm.sp{background:var(--sp-bg);color:var(--sp-color)}
.deco-pill-sm.emb{background:var(--emb-bg);color:var(--emb-color)}
.pool-chip-qty{font-size:10px;color:var(--gray-500)}
.pool-chip-tier{font-size:10px;font-weight:600;color:var(--black);background:var(--gray-100);padding:1px 6px;border-radius:99px}

/* OUTPUT CARDS */
.out-card{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius);margin-bottom:10px;overflow:hidden}
.out-card-hdr{background:var(--black);padding:10px 14px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px}
.out-card-title{font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:800;letter-spacing:.08em;text-transform:uppercase;color:var(--white)}
.out-card-meta{display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.out-pool-tag{font-family:'Barlow Condensed',sans-serif;font-size:9px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;padding:2px 7px;background:rgba(255,255,255,.1);color:rgba(255,255,255,.7);border-radius:2px}
.out-loc-tag{font-size:10px;color:rgba(255,255,255,.4)}
.out-table-wrap{overflow-x:auto}
.out-table{width:100%;border-collapse:collapse;font-size:11px;min-width:300px}
.out-table thead{background:var(--gray-50)}
.out-table th{padding:7px 10px;text-align:right;font-size:8px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--gray-400);border-bottom:1px solid var(--gray-100)}
.out-table th:first-child{text-align:left}
.out-table td{padding:7px 10px;text-align:right;border-bottom:1px solid var(--gray-50);color:var(--gray-500);font-size:11px}
.out-table td:first-child{text-align:left}
.out-table tr:last-child td{border-bottom:none}
.row-active td{background:var(--green-dim)!important;color:var(--green-mid)!important;font-weight:700}
.row-normal:hover td{background:var(--gray-25)}
.td-tier{color:var(--black)!important;font-family:'Barlow Condensed',sans-serif;font-size:12px;font-weight:700}
.tier-lbl{}
.active-dot{display:inline-block;width:6px;height:6px;background:var(--green);border-radius:50%;margin-left:6px;vertical-align:middle}
.td-raw{color:var(--blue)!important;font-weight:600}
.td-rec{color:var(--green-mid)!important;font-weight:800;font-size:13px}
.td-profit{color:var(--purple)!important;font-weight:700}
.th-rec{color:var(--green-mid)!important}
.th-profit{color:var(--purple)!important}
.out-card-footer{padding:7px 14px;background:var(--gray-50);font-size:10px;color:var(--gray-500);border-top:1px solid var(--gray-100)}
.footer-good{color:var(--green-mid);font-weight:600}
.out-disclaimer{font-size:10px;color:var(--gray-300);padding:10px 2px;line-height:1.6}
</style>
</head>
<body>

<!-- TOP BAR -->
<div class="topbar">
  <img src="data:image/png;base64," class="topbar-logo" alt="Elite Apparel">
  <div class="topbar-divider"></div>
  <span class="topbar-label">Quote Builder</span>
  <div class="topbar-spacer"></div>
  <span class="sheet-pill idle" id="sheet-pill">Connecting...</span>
</div>

<!-- ENTRY BAR -->
<div class="entrybar">
  <span class="entry-label">Add Styles</span>
  <input class="entry-input" id="bulk-input" type="text" placeholder="NL6210, ST350, NKDX8730 — comma separated, press Enter">
  <button class="entry-btn primary" id="btn-bulk-add">Add Garments</button>
  <button class="entry-btn secondary" id="btn-add-garment">+ Single</button>
</div>

<!-- APP -->
<div class="app">
  <!-- LEFT: BULK EDITOR -->
  <div class="be-col" id="bulk-editor"></div>

  <!-- RIGHT: OUTPUT -->
  <div class="out-col">
    <div class="out-topbar">
      <div class="out-title">Pricing</div>
      <div class="out-filters">
        <div class="filter-block">
          <div class="filter-block-label">Screen Print Tiers</div>
          <div class="tier-row">
            <button class="tier-ctrl" onclick="selectSpTiers()">All</button>
            <button class="tier-ctrl" onclick="deselectSpTiers()">None</button>
            <span id="tf-sp" style="display:flex;gap:3px;flex-wrap:wrap"></span>
          </div>
        </div>
        <div class="filter-block">
          <div class="filter-block-label">Embroidery Tiers</div>
          <div class="tier-row">
            <button class="tier-ctrl" onclick="selectEmbTiers()">All</button>
            <button class="tier-ctrl" onclick="deselectEmbTiers()">None</button>
            <span id="tf-emb" style="display:flex;gap:3px;flex-wrap:wrap"></span>
          </div>
        </div>
        <div class="filter-block">
          <div class="filter-block-label">Display</div>
          <select class="filter-select" id="filter-price">
            <option value="both">Raw + Recommended</option>
            <option value="raw">Raw only</option>
            <option value="recommended">Recommended only</option>
          </select>
        </div>
      </div>
      <button class="pdf-export-btn" onclick="exportPDF()">
        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2 9h8M6 1v7M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        Export PDF
      </button>
    </div>
    <div class="out-scroll">
      <div id="output-container"><div class="out-empty"><div class="out-empty-icon">📊</div><p>Assign items to pools to generate pricing</p></div></div>
    </div>
  </div>
</div>

<script>
// ── PRICING TABLES — Contract Customizing 2026 ─────────────────────────────
var SP_TIERS=[
  {min:1,  max:3,    p:[18.89,33.17,49.76,66.33,82.92,99.50,116.08,132.65],label:'1–3'},
  {min:4,  max:11,   p:[9.32, 15.36,20.31,25.27,30.21,35.17,40.12, 45.08], label:'4–11'},
  {min:12, max:23,   p:[4.62, 7.47, 10.30,13.15,15.98,18.81,21.64, 24.48], label:'12–23'},
  {min:24, max:47,   p:[2.96, 4.37, 5.83, 7.34, 8.95, 10.45,12.03, 13.61], label:'24–47'},
  {min:48, max:95,   p:[1.95, 2.99, 4.10, 5.02, 6.07, 7.11, 8.14,  9.18],  label:'48–95'},
  {min:96, max:143,  p:[1.64, 2.36, 3.26, 4.08, 4.96, 5.77, 6.57,  7.38],  label:'96–143'},
  {min:144,max:299,  p:[1.23, 1.78, 2.38, 2.89, 3.49, 3.95, 4.55,  5.14],  label:'144–299'},
  {min:300,max:499,  p:[1.04, 1.37, 1.65, 1.95, 2.25, 2.64, 3.03,  3.41],  label:'300–499'},
