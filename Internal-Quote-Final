function getmd(qty,deco){
  if(deco==='embroidery'){if(qty<=35)return 0.55;if(qty<=143)return 0.60;return 0.65;}
  if(qty<=23)return 0.55;if(qty<=143)return 0.60;if(qty<=499)return 0.65;if(qty<=999)return 0.70;return 0.75;
}
function spDeco(qty,colors){
  var t=SP_TIERS.find(function(t){return qty>=t.min&&qty<=t.max;})||SP_TIERS[SP_TIERS.length-1];
  return t.p[Math.min(colors-1,7)];
}
function embDeco(qty,stitches){
  var tier=EMB_TIERS.find(function(t){return qty>=t.min&&qty<=t.max;})||EMB_TIERS[EMB_TIERS.length-1];
  var si=ES.findIndex(function(s){return stitches<=s;});if(si<0)si=ES.length-1;
  return EP[si][tier.qi];
}
function getActiveTier(qty,deco){
  var tiers=deco==='screenprint'?SP_TIERS:EMB_TIERS;
  return tiers.find(function(t){return qty>=t.min&&qty<=t.max;})||tiers[tiers.length-1];
}

// ── STATE ───────────────────────────────────────────────────────────────────
var state={items:[],pools:[],nextPoolId:1,sanmarData:null,sanmarLoading:false,sanmarError:null};
var SHEET_CSV_URL='https://docs.google.com/spreadsheets/d/e/2PACX-1vStUhyLcLdjQ4rtxpRSCfkL7DYQRb32YsXBhhmTC4dahKusFL6xdYpMpBIsAWTfJQ/pub?gid=148251894&single=true&output=csv';

// ── SANMAR ──────────────────────────────────────────────────────────────────
function loadSanmarData(){
  if(!SHEET_CSV_URL||SHEET_CSV_URL==='PLACEHOLDER'){updateSheetStatus();return;}
  state.sanmarLoading=true;updateSheetStatus();
  fetch(SHEET_CSV_URL)
    .then(function(r){return r.text();})
    .then(function(csv){state.sanmarData=parseCSV(csv);state.sanmarLoading=false;updateSheetStatus();})
    .catch(function(){state.sanmarLoading=false;state.sanmarError=true;updateSheetStatus();});
}
function parseCSV(csv){
  function sl(line){var r=[],c='',q=false;for(var i=0;i<line.length;i++){var ch=line[i];if(ch==='"'){q=!q;}else if(ch===','&&!q){r.push(c.trim().replace(/^"|"$/g,''));c='';}else c+=ch;}r.push(c.trim().replace(/^"|"$/g,''));return r;}
  var lines=csv.split('\n'),headers=sl(lines[0]),rows=[];
  for(var i=1;i<lines.length;i++){if(!lines[i].trim())continue;var v=sl(lines[i]),row={};headers.forEach(function(h,j){row[h]=v[j]||'';});rows.push(row);}
  return rows;
}
function lookupStyle(sn){
  if(!state.sanmarData)return null;
  var m=state.sanmarData.filter(function(r){return r['STYLE NUMBER']&&r['STYLE NUMBER'].toUpperCase()===sn.toUpperCase();});
  if(!m.length)return null;
  var base=m.find(function(r){return r['SIZE']&&r['SIZE'].indexOf('(X)S')>-1;})||m[0];
  var price=parseFloat((base['PIECE PRICE']||'').replace(/[^0-9.]/g,''));
  if(isNaN(price)||price===0)return null;
  return{styleNum:base['STYLE NUMBER'],name:base['STYLE DESCRIPTION'],brand:base['BRAND'],wholesale:price};
}
function updateSheetStatus(){
  var el=document.getElementById('sheet-pill');if(!el)return;
  if(state.sanmarLoading){el.className='sheet-pill loading';el.textContent='Loading price sheet...';}
  else if(state.sanmarError){el.className='sheet-pill error';el.textContent='Sheet error — manual entry';}
  else if(state.sanmarData){el.className='sheet-pill ok';el.textContent=state.sanmarData.length.toLocaleString()+' styles loaded';}
  else{el.className='sheet-pill idle';el.textContent='Sheet not connected';}
}

