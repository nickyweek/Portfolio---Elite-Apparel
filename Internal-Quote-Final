    html+='</div>';
  });

  container.innerHTML=html;
}

// ── OUTPUT ────────────────────────────────────────────────────────────────────
function renderOutput(){
  var container=document.getElementById('output-container');
  var filterPrice=document.getElementById('filter-price').value;
  var activeTiers=getActiveTierFilters();
  var ready=state.items.filter(function(i){return i.poolId&&i.wholesale>0;});

  if(ready.length===0){
    container.innerHTML='<div class="out-empty"><div class="out-empty-icon">📊</div><p>Assign items to pools to generate pricing</p></div>';
    return;
  }

  var html='';

  // Pool summary strip
  var activePools=state.pools.filter(function(p){return getItemsInPool(p.id).some(function(i){return i.wholesale>0;});});
  if(activePools.length>0){
    html+='<div class="pool-strip">';
    activePools.forEach(function(pool){
      var items=getItemsInPool(pool.id).filter(function(i){return i.wholesale>0;});
      var tq=items.reduce(function(s,i){return s+i.qty;},0);
      var tier=getActiveTier(tq,pool.deco);
      var isSp=pool.deco==='screenprint';
      html+='<div class="pool-chip"><div class="pool-chip-name">'+pool.name+'</div>';
      html+='<div class="pool-chip-meta"><span class="deco-pill-sm '+(isSp?'sp':'emb')+'">'+(isSp?'SP':'EMB')+'</span>';
      html+='<span class="pool-chip-qty">'+tq+' pcs</span><span class="pool-chip-tier">'+tier.label+'</span></div></div>';
    });
    html+='</div>';
  }

  // Per-item tables
  ready.forEach(function(item){
    var pool=getPool(item.poolId);if(!pool||!pool.locations.length)return;
    var isSp=pool.deco==='screenprint';
    var tiers=isSp?SP_TIERS:EMB_TIERS;
    var poolItems=getItemsInPool(pool.id).filter(function(i){return i.wholesale>0;});
    var totalQty=poolItems.reduce(function(s,i){return s+i.qty;},0);
    var activeTier=getActiveTier(totalQty,pool.deco);
    var locSummary=pool.locations.map(function(l){return isSp?l.name+' ('+l.spColors+'c)':l.name+' ('+(l.embStitches/1000).toFixed(0)+'k stitches)';}).join(' · ');

    html+='<div class="out-card">';
    html+='<div class="out-card-hdr">';
    html+='<div class="out-card-title">'+itemLabelPlain(item)+'</div>';
    html+='<div class="out-card-meta">';
    html+='<span class="out-pool-tag">'+pool.name+'</span>';
    html+='<span class="out-loc-tag">'+locSummary+'</span>';
    html+='</div></div>';
    html+='<div class="out-table-wrap"><table class="out-table"><thead><tr>';
    html+='<th>Tier</th>';
    if(filterPrice!=='recommended'){html+='<th>Garment</th><th>Decoration</th><th>Total Cost</th><th>Raw Price</th>';}
    if(filterPrice!=='raw'){html+='<th class="th-rec">Per Unit Price</th>';}
    html+='<th class="th-profit">Profit / Unit</th>';
    html+='</tr></thead><tbody>';

    tiers.forEach(function(tier){
      if(!activeTiers[tier.label])return;
      var tierQty=isSp?tier.min:item.qty;
      var r=calcAtTierQty(item,tierQty);if(!r)return;
      var isActive=tier.label===activeTier.label;
      html+='<tr class="'+(isActive?'row-active':'row-normal')+'">';
      html+='<td class="td-tier"><span class="tier-lbl">'+tier.label+'</span>'+(isActive?'<span class="active-dot" title="Current pool tier"></span>':'')+'</td>';
      if(filterPrice!=='recommended'){
        html+='<td>$'+r.garment.toFixed(2)+'</td>';
        html+='<td>$'+r.deco.toFixed(2)+'</td>';
        html+='<td>$'+r.totalCost.toFixed(2)+'</td>';
        html+='<td class="td-raw">$'+r.rawPrice.toFixed(2)+'</td>';
      }
      if(filterPrice!=='raw'){html+='<td class="td-rec">$'+r.recommended+'.00</td>';}
      html+='<td class="td-profit">$'+r.profit.toFixed(2)+'</td>';
      html+='</tr>';
    });

    html+='</tbody></table></div>';
    html+='<div class="out-card-footer">';
    html+=pool.name+': '+totalQty+' pcs pooled → <strong>'+activeTier.label+'</strong> tier';
    if(isSp&&totalQty>=144)html+=' &nbsp;·&nbsp; <span class="footer-good">Screen charges waived</span>';
    else if(isSp){var sc=pool.locations.reduce(function(s,l){return s+(l.spColors||1)*20;},0);html+=' &nbsp;·&nbsp; $'+sc+' screen charges/order';}
    html+='</div></div>';
  });

  html+='<div class="out-disclaimer">+$2/unit for 2XL orders &nbsp;·&nbsp; Screen charges: colors × $20/location, waived at 144+ &nbsp;·&nbsp; Profit = Recommended − Total Cost &nbsp;·&nbsp; Pricing: Contract Customizing 2026</div>';
  container.innerHTML=html;
}

